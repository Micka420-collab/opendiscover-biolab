# ─── Core ─────────────────────────────────────────────────────────────
APP_URL="http://localhost:3000"
# Postgres + pgvector (Vercel Marketplace → Neon / Supabase / Vercel Postgres successor)
DATABASE_URL="postgresql://user:password@host:5432/opendiscover?sslmode=require"

# ─── AI ──────────────────────────────────────────────────────────────
# Vercel AI Gateway — single key, multi-provider, observability + fallbacks
# Configure in Vercel: https://vercel.com/docs/ai-gateway
AI_GATEWAY_API_KEY=""

# ─── Auth ────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET="generate-with: openssl rand -hex 32"
BETTER_AUTH_URL="http://localhost:3000"
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ─── Workflows ───────────────────────────────────────────────────────
# Inngest — durable discovery pipeline
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# ─── Realtime / rate limiting (Upstash Redis) ────────────────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── Observability ───────────────────────────────────────────────────
SENTRY_DSN=""
POSTHOG_API_KEY=""
POSTHOG_HOST="https://eu.i.posthog.com"
NEXT_PUBLIC_POSTHOG_KEY=""

# ─── Email ───────────────────────────────────────────────────────────
RESEND_API_KEY=""

# ─── External data sources (optional, raises rate limits) ─────────────
NCBI_API_KEY=""
EUROPE_PMC_API_KEY=""

# ─── Pipeline thresholds ─────────────────────────────────────────────
NOVELTY_THRESHOLD="0.75"
CORROBORATION_MIN="2"
ENABLE_DISCOVERY_PIPELINE="true"

# ─── Vercel Sandbox (auto-detected on Vercel) ─────────────────────────
# VERCEL_SANDBOX_TOKEN=""

# ─── DOI minting ─────────────────────────────────────────────────────
ZENODO_ACCESS_TOKEN=""

# ─── Security ────────────────────────────────────────────────────────
CRON_SECRET="generate-with: openssl rand -hex 32"
