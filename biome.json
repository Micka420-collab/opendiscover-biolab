{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "files": {
    "ignore": [".next", "node_modules", ".vercel", "drizzle/meta", "public"]
  },
  "organizeImports": { "enabled": true },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": { "noExplicitAny": "warn", "noConsoleLog": "off" },
      "style": { "useImportType": "error", "useNodejsImportProtocol": "error" },
      "correctness": { "noUnusedImports": "error", "noUnusedVariables": "warn" },
      "performance": { "noAccumulatingSpread": "warn" }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": { "quoteStyle": "single", "trailingCommas": "all", "semicolons": "always" }
  }
}
